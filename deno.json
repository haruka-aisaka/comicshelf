{
  "tasks": {
    "check": "deno check src/ web/server.ts web/routes/ tests/db tests/indexer tests/reader tests/web tests/_helpers tests/comicinfo",
    "test": "deno test -A tests/db tests/indexer tests/reader tests/web tests/comicinfo",
    "test:e2e": "deno test -A --no-check tests/e2e/",
    "web": "deno run -A --watch web/server.ts",
    "index": "deno run -A src/indexer/cli.ts",
    "fmt": "deno fmt src/ web/ tests/"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.6.0",
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0",
    "@zip-js/zip-js": "jsr:@zip-js/zip-js@^2.7.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  }
}
