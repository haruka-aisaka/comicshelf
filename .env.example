# ホスト側の漫画ライブラリのパス (cbz/zip を再帰スキャンする)
COMICS_DIR=/path/to/your/comics

# ホスト側公開ポート
COMICSHELF_PORT=8080

# 待ち受けアドレス。
# - 省略時は 0.0.0.0 (全インターフェース)
# - Tailscale IPを指定すればVPN経由のみアクセス可能になる
#   tailscale ip -4 の結果を入れる
# BIND_ADDR=100.x.y.z

# タイムゾーン
TZ=Asia/Tokyo

# NAS等でファイル所有権を合わせる場合に使用 (compose.yaml で有効化)
# PUID=1000
# PGID=1000
